{
  "version": "0.2.4",
  "updated_at": "2026-06-17",
  "architecture": {
    "core": "Agent Access is a thin Codex plugin and registry. It does not bundle user sessions, cookies, tokens, private browser data, or local CLI binaries.",
    "session_boundary": "Each companion CLI owns its local auth/session store on the user machine. Registry entries may describe login/update commands, but never contain credentials.",
    "evolution_loop": "Use a CLI, reflect on agent friction, improve CLI or references, dogfood the realistic flow, then contribute a scrubbed patch/draft for maintainer review.",
    "swarm_governance": "Users can submit CLI improvements, references, and registry patches as explicit reviewed contributions. Nothing uploads automatically; maintainers approve before merge/release.",
    "upgrade_model": "Agent Access updates through Codex plugin marketplace upgrades. Companion CLIs update through their own declared update commands or upstream package managers."
  },
  "entries": [
