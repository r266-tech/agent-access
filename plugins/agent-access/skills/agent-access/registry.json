      "name": "wechat-cli",
      "aliases": [
        "wx-cli",
        "wechat",
        "weixin",
        "local-wechat"
      ],
      "kind": "local-data",
      "targets": [
        "WeChat",
        "Weixin",
        "local WeChat 4.x database",
        "微信"
      ],
      "command": "wechat-cli",
      "description": "Read local WeChat conversations, contacts, groups, media, Moments, favorites, transfers, red packets, unread chats, and full-text search from the user machine. It does not send messages or control the WeChat UI.",
      "repository": "https://github.com/r266-tech/wechat-cli",
      "install": {
        "type": "script",
        "trust_boundary": "downloads the public release installer; user WeChat data and keys remain local",
        "commands": [
          {
            "os": "darwin",
            "command": [
              "bash",
              "-lc",
              "curl -fsSL https://raw.githubusercontent.com/r266-tech/wechat-cli/main/scripts/install-release.sh | env WECHAT_CLI_INSTALL_JSON=1 zsh"
            ],
            "description": "Install latest macOS release."
          },
          {
            "os": "win32",
            "command": [
              "powershell",
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-Command",
              "[Environment]::SetEnvironmentVariable('WECHAT_CLI_INSTALL_JSON','1','Process'); irm https://raw.githubusercontent.com/r266-tech/wechat-cli/main/scripts/install-release.ps1 | iex"
            ],
            "description": "Install latest Windows release."
          }
        ],
        "hint": "Install from https://github.com/r266-tech/wechat-cli, then run agent-access doctor wechat-cli --run."
      },
      "update": {
        "type": "self-update",
        "commands": [
          {
            "command": [
              "wechat-cli",
              "update"
            ],
            "description": "Update an existing release install to the latest GitHub release."
          }
        ],
        "hint": "Run wechat-cli update, then agent-access doctor wechat-cli --run."
      },
      "doctor": [
        "wechat-cli",
        "--help"
      ],
      "auth": {
        "required_for": [
          "local WeChat account data reads"
        ],
        "methods": [
          "local-app-session"
        ],
        "broker": "delegates-to-cli",
        "commands": {
          "status": [
            "wechat-cli",
            "status"
          ],
          "doctor": [
            "wechat-cli",
            "agent"
          ]
        },
        "local_state_only": true
      },
      "read_write": "read-only",
      "outputs": [
        "json",
        "ids",
